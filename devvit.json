{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "putt-together-game",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "Create the Putt Together game post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Reset world (admin)",
        "description": "Wipe all holes, records and scores; reseeds fresh",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/reset-world"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "putt_together_gam_dev"
  },
  "scheduler": {
    "tasks": {
      "daily-tee-off": {
        "endpoint": "/internal/scheduler/daily",
        "cron": "0 6 * * *"
      }
    }
  },
  "marketingAssets": {
    "icon": "assets-icon.png"
  }
}
